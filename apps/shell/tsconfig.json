{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "types": ["vite/client", "@testing-library/jest-dom"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@cellar/shared": ["../../packages/shared/src/index.ts"],
      "@cellar/shared/*": ["../../packages/shared/src/*"],
      "@cellar/ui": ["../../packages/ui/src/index.ts"],
      "@cellar/ui/*": ["../../packages/ui/src/*"],
      "@cellar/shell-contract": ["../../packages/shell-contract/src/index.ts"],
      "@cellar/feature-vault": ["../../packages/feature-vault/src/index.tsx"],
      "@cellar/feature-vault/manifest": ["../../packages/feature-vault/src/manifest.ts"],
      "@cellar/feature-toolbox": ["../../packages/feature-toolbox/src/index.ts"],
      "@cellar/feature-toolbox/manifest": ["../../packages/feature-toolbox/src/manifest.ts"],
      "@cellar/feature-account": ["../../packages/feature-account/src/index.ts"],
      "@cellar/feature-account/manifest": ["../../packages/feature-account/src/manifest.ts"],
      "@cellar/api/app-type": ["../api/src/app.ts"]
    }
  },
  "include": ["src", ".storybook"],
  "exclude": ["dist", "node_modules", "storybook-static"]
}
