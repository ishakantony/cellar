{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@cellar/shared": ["../../packages/shared/src/index.ts"],
      "@cellar/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src", "drizzle.config.ts"],
  "exclude": ["dist", "node_modules"]
}
