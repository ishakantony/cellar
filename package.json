{
  "name": "cellar",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter shell dev & bun run --filter api dev",
    "build": "bun run --filter @cellar/shared build && bun run --filter @cellar/ui build && bun run --filter @cellar/shell-contract build && bun run --filter @cellar/feature-vault build && bun run --filter @cellar/feature-toolbox build && bun run --filter @cellar/feature-account build && bun run --filter shell build && bun run --filter api build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test-storybook": "bun run --filter @cellar/ui test-storybook",
    "storybook": "bun run --filter @cellar/ui storybook",
    "build-storybook": "bun run --filter @cellar/ui build-storybook",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:ui:slowMo": "SLOW_MO=true playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:setup": "tsx scripts/setup-test-db.ts",
    "test:e2e": "bun run e2e:setup && playwright test",
    "test:e2e:ui": "bun run e2e:setup && playwright test --ui",
    "db:generate": "bun run --filter api db:generate",
    "db:migrate": "bun run --filter api db:migrate",
    "db:reset": "bun run --filter api db:reset",
    "db:studio": "bun run --filter api db:studio",
    "auth:sync-clients": "bun run --filter api exec tsx src/auth/oidc/sync-cli.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "check:all": "bun run format:check && bun run lint && bun run test && bun run test-storybook && bun run test:e2e && bun run build"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix",
      "vitest run --reporter=dot --passWithNoTests"
    ],
    "*.{json,md,css,scss,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-storybook": "^10.3.5",
    "globals": "^15.13.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.4"
  }
}
