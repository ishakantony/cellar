# .env.test
NODE_ENV=test
# Enable E2E test mode (disables CSRF for testing only)
E2E_TEST_MODE=true
# NEVER set this in production!
DATABASE_URL=postgresql://cellar:cellar@localhost:5432/cellar_test
BETTER_AUTH_SECRET=test-secret-for-e2e-tests-do-not-use-in-production
# WARNING: This is intentionally weak for testing only
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
UPLOAD_DIR=./uploads-test
MAX_FILE_SIZE=10485760
